# Copy to `.env` and fill in your JSONBin credentials.
# Create a free bin at https://jsonbin.io — store `{ "items": [] }` as the initial record.

VITE_JSONBIN_BIN_ID=your_bin_id_here
VITE_JSONBIN_ACCESS_KEY=your_read_access_key_here

# Master key is entered in the Admin panel (not stored in .env) for security.
